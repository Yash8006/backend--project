# ──────────────────────────────────────────────────
# Root-level .gitignore for video-tube monorepo
# ──────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ── SECRETS – NEVER COMMIT ────────────────────────
**/.env
**/.env.local
**/.env.development
**/.env.development.local
**/.env.test
**/.env.test.local
**/.env.production
**/.env.production.local

# ── Dependencies ──────────────────────────────────
**/node_modules/
**/jspm_packages/

# ── Build outputs ─────────────────────────────────
**/dist/
**/dist-ssr/
**/.next/
**/out/
**/.nuxt/
**/.output/

# ── Logs ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Cache / Temp ──────────────────────────────────
**/.cache/
**/.parcel-cache/
**/.rpt2_cache/
**/.fusebox/
**/.serverless/
**/.dynamodb/
**/.yarn/cache
**/.yarn/unplugged
**/.pnp.*

# ── TypeScript ────────────────────────────────────
**/*.tsbuildinfo

# ── Misc ──────────────────────────────────────────
*.tgz
*.local
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Backend specific ──────────────────────────────
Backend/public/temp/*
!Backend/public/temp/.gitkeep
